	setAttr ".lyr[1].szd" -type "string" (
		"#usda 1.0\n(\n    customLayerData = {\n        string License = \"CC BY 4.0\"\n        string Version = \"1.1\"\n    }\n    defaultPrim = \"standard_shader_ball_scene\"\n    endTimeCode = 3\n    framesPerSecond = 24\n    metersPerUnit = 0.01\n    startTimeCode = 3\n    subLayers = [\n        @./layers/example_materials.usda@,\n        @./layers/shaderball.usda@,\n        @./layers/camera.usda@,\n        @./layers/environment.usda@\n    ]\n    timeCodesPerSecond = 24\n    upAxis = \"Y\"\n)\n\ndef Xform \"standard_shader_ball_scene\" (\n    kind = \"group\"\n    variants = {\n        string surface_geometry = \"subdiv\"\n    }\n    prepend variantSets = \"surface_geometry\"\n)\n{\n    def Xform \"shader_ball\" (\n        active = true\n        kind = \"component\"\n    )\n    {\n        token visibility = \"invisible\"\n    }\n\n    over \"lights\"\n    {\n        over \"emitterLeft\"\n        {\n            over \"light\"\n            {\n                float3[] extent = [(-7.4800005, -7.4800005, -0), (7.4800005, 7.4800005, 0)]\n                float inputs:diffuse = 0\n                float inputs:exposure = 2.5179856\n"
		+ "                float inputs:intensity = 15.107914\n                color3f inputs:shadow:color\n                bool inputs:shadow:enable = 1\n            }\n        }\n\n        over \"emitterTop\"\n        {\n            over \"light3\"\n            {\n                float3[] extent = [(-12.18, -12.18, -0), (12.18, 12.18, 0)]\n                float inputs:exposure = 2\n                float inputs:intensity = 5\n                color3f inputs:shadow:color\n                bool inputs:shadow:enable = 1\n            }\n\n            over \"light2\"\n            {\n                float3[] extent = [(-12.18, -12.18, -0), (12.18, 12.18, 0)]\n                float inputs:intensity = 3.23741\n                color3f inputs:shadow:color\n                bool inputs:shadow:enable = 1\n            }\n\n            over \"light1\"\n            {\n                float3[] extent = [(-12.18, -12.18, -0), (12.18, 12.18, 0)]\n                float inputs:intensity = 8.633094\n                color3f inputs:shadow:color\n                bool inputs:shadow:enable = 1\n"
		+ "            }\n\n            over \"light0\"\n            {\n                float3[] extent = [(-12.18, -12.18, -0), (12.18, 12.18, 0)]\n                float inputs:intensity = 8.633094\n                color3f inputs:shadow:color\n                bool inputs:shadow:enable = 1\n            }\n        }\n    }\n    variantSet \"surface_geometry\" = {\n        \"subdiv\" {\n            over \"shader_ball\" (\n                prepend references = @./material_surface_geo/subdiv.usda@\n            )\n            {\n            }\n\n        }\n        \"triangulated\" {\n            over \"shader_ball\" (\n                prepend references = @./material_surface_geo/triangulated.usda@\n            )\n            {\n                over \"material_surface\"\n                {\n                    token subdivisionScheme = \"none\"\n                }\n            }\n\n        }\n    }\n}\n\n");
